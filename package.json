{
  "name": "opendick",
  "version": "0.1.0",
  "description": "An installable Claude Code plugin to control intimate hardware (Buttplug/Intiface) by chatting — with a live web console, a built-in simulator, plus video (funscript) and game modes.",
  "type": "module",
  "bin": {
    "opendick": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/opendick.mjs --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\"",
    "start": "node dist/index.js",
    "console": "node dist/index.js --console-only",
    "dev": "tsx watch src/index.ts",
    "dev:console": "tsx watch src/index.ts -- --console-only"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "buttplug": "^3.2.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
